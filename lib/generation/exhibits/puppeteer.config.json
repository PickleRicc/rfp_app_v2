{
  "headless": true,
  "args": [
    "--no-sandbox",
    "--disable-setuid-sandbox",
    "--disable-dev-shm-usage",
    "--disable-accelerated-2d-canvas",
    "--disable-gpu",
    "--font-render-hinting=none"
  ],
  "defaultViewport": {
    "width": 1200,
    "height": 800,
    "deviceScaleFactor": 2
  }
}
